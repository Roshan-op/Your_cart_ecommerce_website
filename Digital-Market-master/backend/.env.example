# ===================== GMAIL SMTP CONFIGURATION =====================
# Gmail SMTP Email Setup Instructions:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to App passwords section (at the bottom)
# 4. Select Mail and Windows Computer
# 5. Copy the 16-character password shown
# 6. Add email and app password below

# Your Gmail address
EMAIL_HOST_USER=your-email@gmail.com

# Gmail App Password (16 characters - NOT your regular password)
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx

# Email Configuration
DEFAULT_FROM_EMAIL=your-email@gmail.com
ADMIN_EMAIL=your-email@gmail.com

# ===================== DJANGO SETTINGS =====================
DEBUG=True
SECRET_KEY=your_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (optional, SQLite is default)
# DATABASE_URL=sqlite:///db.sqlite3
